<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
    xmlns="https://github.com/spotbugs/filter/3.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

  <!--
    Keep this file short. Every entry must carry a justification comment and be
    scoped as narrowly as possible. Blanket exclusions are not acceptable.
  -->

  <!--
    CT_CONSTRUCTOR_THROW flags validating constructors as finalizer-attack
    vectors. The JDK finalizer is deprecated for removal, none of these types
    hold security-sensitive state before validation completes, and fail-fast
    validation in constructors is a deliberate design rule of this codebase.
  -->
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>

  <!--
    A transport's contract is to hand its I/O streams to the protocol layer, so
    returning them is not an accidental exposure of internal state.
  -->
  <Match>
    <Class name="~io\.github\.orhaugh\.chord\.transport\..*Transport"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!--
    CHord's API contract is unchecked exceptions. The catch-cleanup-rethrow idiom
    (mark the connection broken, close the transport, rethrow) necessarily catches
    and rethrows RuntimeException; flagging every such site is noise.
  -->
  <Match>
    <Bug pattern="THROWS_METHOD_THROWS_RUNTIMEEXCEPTION"/>
  </Match>

  <!--
    Testcontainers containers are stateful fixtures, not value objects; the
    superclass equals is identity-like and adding configuration fields to a
    container subclass does not create a meaningful equality contract to honour.
  -->
  <Match>
    <Class name="io.github.orhaugh.chord.testkit.ClickHouseServerContainer"/>
    <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
  </Match>

  <!--
    A lease's documented contract is to expose the underlying connection for its
    duration; that is the feature, not an accidental representation leak.
  -->
  <Match>
    <Class name="io.github.orhaugh.chord.client.PooledConnection"/>
    <Method name="connection"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!--
    The operation listener is a shared callback by design: options hand the configured
    listener to the connection machinery, exactly as documented.
  -->
  <Match>
    <Class name="io.github.orhaugh.chord.client.ConnectionOptions"/>
    <Method name="operationListener"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!--
    JFR event fields are written by CHord and read reflectively by the Flight
    Recorder runtime, so static analysis sees them as unread.
  -->
  <Match>
    <Class name="~io\.github\.orhaugh\.chord\.client\.JfrEvents\$.*"/>
    <Bug pattern="URF_UNREAD_FIELD"/>
  </Match>

  <!--
    The JDBC API contract requires these accessors to return the owning objects:
    ResultSet.getStatement, Statement.getConnection and DatabaseMetaData.getConnection
    hand back the very instances the caller already holds references to.
  -->
  <Match>
    <Or>
      <And>
        <Class name="io.github.orhaugh.chord.jdbc.ChordResultSet"/>
        <Method name="getStatement"/>
      </And>
      <And>
        <Class name="io.github.orhaugh.chord.jdbc.ChordDatabaseMetaData"/>
        <Method name="getConnection"/>
      </And>
      <And>
        <Class name="io.github.orhaugh.chord.jdbc.ChordStatement"/>
        <Or>
          <Method name="getConnection"/>
          <Method name="getResultSet"/>
        </Or>
      </And>
    </Or>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>

  <!--
    JDBC dictates both spellings: DatabaseMetaData.getURL is spec mandated and getUrl is the
    established DataSource bean property convention. The JDBC spec also defines getBytes to
    return null for SQL NULL, not an empty array.
  -->
  <Match>
    <Class name="io.github.orhaugh.chord.jdbc.ChordDataSource"/>
    <Method name="getUrl"/>
    <Bug pattern="NM_CONFUSING"/>
  </Match>
  <Match>
    <Class name="io.github.orhaugh.chord.jdbc.ChordResultSet"/>
    <Method name="getBytes"/>
    <Bug pattern="PZLA_PREFER_ZERO_LENGTH_ARRAYS"/>
  </Match>
</FindBugsFilter>
